{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application, including admins.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog post for the Nhip Song 360 section.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "excerpt", "content", "image", "date", "category", "createdAt", "authorId"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "price", "image", "category", "stock", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "string" },
        "contactPhone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "shippingAddress", "contactPhone", "createdAt"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global configuration for the website appearance and content.",
      "type": "object",
      "properties": {
        "brandBlue": { "type": "string", "description": "Primary brand color (hex)" },
        "brandOrange": { "type": "string", "description": "Secondary brand color (hex)" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string", "format": "uri" },
        "aboutImage": { "type": "string", "format": "uri" },
        "bannerImage": { "type": "string", "format": "uri" },
        "partnerBannerImage": { "type": "string", "format": "uri" },
        "productHighlightImage": { "type": "string", "format": "uri" },
        "contactPhone": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactAddress": { "type": "string" },
        "facebookUrl": { "type": "string", "format": "uri" },
        "instagramUrl": { "type": "string", "format": "uri" },
        "youtubeUrl": { "type": "string", "format": "uri" },
        "footerDescription": { "type": "string" }
      }
    },
    "Page": {
      "title": "Page",
      "description": "Content for static pages like About or Contact.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "sections": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/blogPosts/{postId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Stores blog posts."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores product information."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores customer orders."
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/SiteSettings" },
      "description": "Stores global site settings."
    },
    "/pages/{pageId}": {
      "schema": { "$ref": "#/entities/Page" },
      "description": "Stores static page content."
    },
    "/categories/{categoryId}": {
      "schema": { "type": "object" },
      "description": "Stores categories for posts and products."
    }
  }
}
